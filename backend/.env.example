# Server
PORT=3001

# Database
# Use DB_SOCKET for Unix socket (e.g. DBngin: /tmp/mysql_3306.sock)
# OR use DB_HOST + DB_PORT for TCP connections
DB_SOCKET=/tmp/mysql_3306.sock
# DB_HOST=localhost
# DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=transport
DB_CONNECTION_LIMIT=10

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
